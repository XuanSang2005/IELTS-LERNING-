PORT=4000
MONGODB_URI=mongodb://localhost:27017/meridian
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:5173

# ── Anthropic (AI grading) ─────────────────────────────────────────
# Optional. When empty, the backend returns deterministic mock grading
# based on word count — the full end-to-end flow works without a key.
# Drop a real key from https://console.anthropic.com to enable live Claude grading.
ANTHROPIC_API_KEY=

# ── Pricing (VND, integers only) ───────────────────────────────────
# Both prices are required once you expose /pricing or /payments. The
# frontend pulls them at runtime — NEVER hardcode on the client.
PRO_MONTHLY_PRICE_VND=199000
PRO_COHORT_PRICE_VND=1499000

# ── Casso / bank transfer payments ─────────────────────────────────
# Generate an API key in the Casso dashboard (https://dashboard.casso.vn)
# and paste the WEBHOOK secret below. Casso sends it as
# `Authorization: Apikey <token>` on every webhook call — we reject any
# webhook that doesn't match (constant-time compare).
CASSO_WEBHOOK_SECRET=

# Replay-protection window. Any transaction whose `when` timestamp is older
# than this (in seconds) is dropped. 5 minutes is generous for Casso's
# real-time delivery and survives modest clock drift.
CASSO_WEBHOOK_MAX_AGE_SECONDS=300

# Your bank account that receives transfers. These are surfaced verbatim
# in the QR + payment page. Replace with Meridian's real account before
# accepting real money.
#   BANK_BIN: 6-digit VietQR BIN (see https://api.vietqr.io/v2/banks)
#     970422 = MB, 970436 = Vietcombank, 970407 = Techcombank,
#     970416 = ACB, 970415 = Vietinbank, 970418 = BIDV
MERIDIAN_BANK_NAME=MB Bank
MERIDIAN_BANK_CODE=MB
MERIDIAN_BANK_BIN=970422
MERIDIAN_BANK_ACCOUNT_NO=0123456789
MERIDIAN_BANK_ACCOUNT_HOLDER=NGUYEN VAN A

# How long a payment session stays open (minutes). After this, the QR
# expires and the user must start a new session.
PAYMENT_TTL_MINUTES=15
